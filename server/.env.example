# Port d'écoute du serveur API
PORT=4000

# Origine(s) autorisée(s) pour le CORS (URL du frontend, sans slash final).
# Plusieurs origines possibles séparées par des virgules.
CLIENT_ORIGIN=http://localhost:5173,https://premium-planner-app-saas.vercel.app

# Secrets JWT - a generer avec `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
# NE JAMAIS committer les vraies valeurs en production.
JWT_ACCESS_SECRET=changeme_access_secret_dev_only_replace_me
JWT_REFRESH_SECRET=changeme_refresh_secret_dev_only_replace_me

# Duree de vie des tokens
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Mettre à true dès que le backend est servi en HTTPS (Railway/Render/Fly.io/...).
# Active les cookies Secure ET SameSite=None, indispensable pour que les
# cookies passent entre le frontend (ex: Vercel) et ce backend qui sont sur
# des domaines différents.
COOKIE_SECURE=false

# Chemin du fichier SQLite
DB_PATH=./data/planner.db
